{
  "manifest_version": 3,
  "name": "Contract Review",
  "version": "1.0.0",
  "description": "Try Contract Review software to analyze business contracts, check legal documents, and simplify agreement review online.",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:8000/*"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
